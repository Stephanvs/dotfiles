// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "ui_font_size": 14.0,
  "auto_update": false,
  "diff_view_style": "split",
  "show_whitespaces": "boundary",
  "selection_highlight": true,
  "edit_predictions": {
    "provider": "zed",
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": false,
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "full-access",
      },
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
      "default_config_options": {
        "mode": "build",
      },
    },
    "claude-acp": {
      "type": "registry",
      "default_mode": "acceptEdits",
    },
  },
  "auto_signature_help": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 5000,
    },
  },
  "ssh_connections": [
    {
      "host": "100.73.236.91",
      "username": "stephanvs",
      "projects": [
        {
          "paths": ["~/Code"],
        },
        {
          "paths": ["~/actions-runner"],
        },
        {
          "paths": ["~/codeql"],
        },
        {
          "paths": ["~/source"],
        },
        {
          "paths": ["~/source/lazycode"],
        },
      ],
      "nickname": "fiji",
    },
  ],
  "vertical_scroll_margin": 8,
  "terminal": {
    "font_family": "BerkeleyMono Nerd Font",
    "dock": "bottom",
  },
  "project_panel": {
    "auto_reveal_entries": false,
    "git_status": true,
  },
  "hide_mouse": "on_typing_and_movement",
  "cursor_blink": false,
  "cursor_shape": "bar",
  "agent": {
    "new_thread_location": "new_worktree",
    "show_merge_conflict_indicator": true,
    "use_modifier_to_send": true,
    "thinking_display": "preview",
    "play_sound_when_agent_done": "when_hidden",
    "default_profile": "write",
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-5",
    },
    "commit_message_model": {
      "provider": "lmstudio",
      "model": "qwen/qwen3.5-9b",
    },
  },
  "language_models": {
    "lmstudio": {
      "api_url": "http://hawaii:1234/api/v0",
    },
  },
  "tabs": {
    "show_diagnostics": "errors",
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": true,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "ui_font_features": {
    "liga": true,
  },
  "buffer_font_family": "BerkeleyMono Nerd Font",
  "buffer_font_features": {
    "liga": true,
  },
  "base_keymap": "VSCode",
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "dark",
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
  },
  "vim": {
    "use_system_clipboard": "always",
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "buffer_font_size": 12.0,
  "use_autoclose": false,
  "toolbar": {
    "agent_review": true,
    "code_actions": true,
    "quick_actions": true,
    "breadcrumbs": false,
    "selections_menu": false,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false,
    },
  },
  "minimap": {
    "show": "always",
    "current_line_highlight": "all",
    "thumb": "hover",
  },
}
